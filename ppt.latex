%------------------------------------------------
\section{Protocole (synthèse)}

\begin{frame}{Protocole (synthèse)}
\begin{itemize}
  \item Protocole texte sur TCP : commandes une par ligne (facile à lire et debuguer)
  \item Commandes client → serveur : `GETD`, `GETL`, `ADDL`, `MDFL`, `RMVL`
  \item Notifications serveur → client : `LINE`, `ADDL`, `RMVL`, `DONE`, `ERRL`
  \item Messages inter-serveurs : `PEERSYNC`, `SYNC ...` ; maître : `FWDL reqId cmd` / `ORDER seq reqId cmd`
\end{itemize}
\end{frame}

%------------------------------------------------
\section{Implémentation et choix techniques}

\begin{frame}{Implémentation et choix techniques}
\begin{itemize}
  \item Langage : Java 21 ; client GUI via JavaFX (Gradle)
  \item Modèle de concurrence : thread par connexion (simplifie le code et le debug)
  \item Synchronisation document : `synchronized` pour versions simples ; Raft pour consensus distribué
  \item Tests automatisés : `AutoClient` (barrière file-based) et `BenchClient` pour mesures
\end{itemize}
\end{frame}

%------------------------------------------------
\section{Validation và montée en charge}

\begin{frame}{Benchmarks — Scénario A}
\begin{itemize}
  \item Scénario A : 3 serveurs (1 maître + 2 esclaves), nombre de clients variable
  \item Mesures (20 ops/client) : latence moyenne stable ~3.5–4 ms ; débit augmente avec clients
\end{itemize}
\begin{center}
  \includegraphics[width=0.85\textwidth]{bench_scenario_A.png}
\end{center}
\end{frame}

\begin{frame}{Benchmarks — Scénario B}
\begin{itemize}
  \item Scénario B : 4 clients fixes, nombre de serveurs variable
  \item Observations : latence augmente quand le nombre de serveurs devient grand (charge sur le maître)
\end{itemize}
\begin{center}
  \includegraphics[width=0.85\textwidth]{bench_scenario_B.png}
\end{center}
\end{frame}

%------------------------------------------------
\section{Tolérance aux pannes}

\begin{frame}{Tolérance aux pannes}
\begin{itemize}
  \item `ServerMasterFaulty` montre comportement avec SPOF (gel + arrêt du maître)
  \item `ServerRaft` : implémentation Raft à 3 nœuds — timeouts 1500–3000 ms, heartbeat 300 ms
  \item Résultat : avec quorum 2/3, le cluster continue après panne d'un nœud
\end{itemize}
\end{frame}

%------------------------------------------------
\section{Comment exécuter}

\begin{frame}[fragile]{Compilation et exécution}
\begin{itemize}
  \item Compiler les serveurs et clients (depuis `editor/src/main/java`):
  \begin{verbatim}
  cd editor/src/main/java
  javac *.java
  \end{verbatim}
  \item Lancer le client graphique (depuis `editor/`):
  \begin{verbatim}
  ./gradlew run
  \end{verbatim}
  \item Scripts d'autotest et benchmark dans `editor/scripts/` (ex.: `./scripts/bench.sh`)
\end{itemize}
\end{frame}

%------------------------------------------------
\section{Conclusion}

\begin{frame}{Conclusion}
\begin{itemize}
  \item Projet couvert : architectures centralisée, push, fédérée, maître-esclave, Raft
  \item Mesures : benchs locaux donnent tendances fiables, valeurs absolues indicatives
  \item Travail possible : distribuer sur machines séparées, améliorer gestion des conflits (OT/CRDT)
\end{itemize}
\end{frame}

