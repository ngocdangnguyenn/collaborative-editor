%------------------------------------------------
\section{Introduction}

\begin{frame}{Introduction}
\begin{itemize}
  \item Projet : implémentation d'un éditeur de texte collaboratif en Java
  \item Objectif : expérimenter plusieurs architectures (centralisé, fédéré, maître-esclave, Raft)
  \item Livrables : code Java, scripts de test, scripts de benchmark, rapport et slides
\end{itemize}
\end{frame}

%------------------------------------------------
\section{Architecture générale}

\begin{frame}{Architecture générale}
\begin{itemize}
  \item Composants principaux : serveurs (plusieurs variantes), clients automatiques, client graphique
  \item Déploiement local pour tests : plusieurs processus Java sur localhost
  \item Scripts d'automatisation dans `editor/scripts/` (compilation, déploiement, tests)
\end{itemize}
\end{frame}

%------------------------------------------------
\section{Rôles des composants}

\begin{frame}{Rôles des composants}
\begin{itemize}
  \item `ServerCentral` : modèle pull simple (GETD)
  \item `ServerCentralPush` : notifications push vers clients connectés
  \item `ServerFederated` : propagation entre pairs avec message `PEERSYNC` / `SYNC`
  \item `ServerMaster` : ordre centralisé des opérations via `FWDL` / `ORDER`
  \item `ServerDispatch` : répartiteur (GETSERVER) pour masquer adresses réelles
  \item `ServerRaft` : implémentation Raft pour tolérance aux pannes (3 nœuds)
\end{itemize}
\end{frame}

%------------------------------------------------
\section{Fonctionnalités implémentées}

\begin{frame}{Fonctionnalités implémentées}
\begin{itemize}
  \item Édition ligne par ligne : `ADDL`, `MDFL`, `RMVL` avec versions par ligne
  \item Mode pull et mode push pour clients (rafraîchissement et notifications)
  \item Propagation entre serveurs : pair-à-pair (`PEERSYNC` / `SYNC`)
  \item Maître logique pour ordre global : `FWDL` / `ORDER` avec `reqId` pour corrélation
  \item Raft : élections, réplication et commit avec logs (AppendEntries)
  \item Scripts d'automatisation : tests de convergence et benchmarks (barrière file-based)
\end{itemize}
\end{frame}

%------------------------------------------------
\section{Choix de conception}

\begin{frame}{Choix de conception importants}
\begin{itemize}
  \item Protocole texte sur TCP : simple et débogable (netcat pour tests manuels)
  \item `Thread-per-connection` : clarté et rapidité de développement
  \item Versions par ligne pour détection d'écriture concurrente (ERRL)
  \item Séparation des responsabilités : dispatch, master, fédéré, raft
\end{itemize}
\end{frame}

%------------------------------------------------
\section{Données et tests}

\begin{frame}{Méthodologie de test}
\begin{itemize}
  \item Tests fonctionnels : `AutoClient` (8 clients, 20 ops chacun) + barrières
  \item Benchmarks : `BenchClient` pour latence / débit (20 ops/client mesurés)
  \item Répétitions et observation de la variance : 20 ops stable, 100 ops plus bruité
  \item Limitation : tests exécutés localement sur une seule machine (valeurs indicatives)
\end{itemize}
\end{frame}

%------------------------------------------------
\section{Résultats clés}

\begin{frame}{Résultats clés (résumé)}
\begin{itemize}
  \item Scénario A (3 serveurs) : latence ~3.4–4.0 ms ; débit augmente jusqu'à ~1025 ops/s
  \item Scénario B (serveurs variables) : latence croissante quand maître devient goulot
  \item Raft : tolérance aux pannes confirmée avec quorum 2/3 (continuité après panne)
  \item Remarque : débit absolu bruité en local, mais tendances cohérentes
\end{itemize}
\end{frame}

%------------------------------------------------
\section{Difficultés et corrections}

\begin{frame}{Difficultés rencontrées}
\begin{itemize}
  \item Boucles de réplication initiales entre pairs → solution `PEERSYNC`/`SYNC`
  \item Format `AppendEntries` mal parsé → ajout d'un séparateur explicite
  \item Mesures bruitées en local (ERRL, barrières, GC) → répétitions et choix 20 ops pour rapport
  \item Gestion des pannes maître → implémentation Raft + démonstration `ServerMasterFaulty`
\end{itemize}
\end{frame}

%------------------------------------------------
\section{Guide de démonstration}

\begin{frame}[fragile]{Script de démonstration rapide}
\begin{verbatim}
# depuis editor/src/main/java
javac *.java

# lancer un maître + 2 esclaves
java ServerMaster 5000 peers.cfg &
java ServerMaster 5001 peers.cfg &
java ServerMaster 5002 peers.cfg &

# lancer BenchClients via script (ex : editor/scripts/bench.sh)
./editor/scripts/bench.sh
\end{verbatim}
\end{frame}

%------------------------------------------------
\section{Packaging pour rendu}

\begin{frame}{Packaging pour rendu}
\begin{itemize}
  \item Archive zip demandée : inclure tout `editor/`, `RAPPORT.md`, `RAPPORT.pdf`, `README.md`
  \item Un seul rendu par équipe — vérifier `README.md` avec les noms et instructions
  \item Commande rapide pour créer l'archive (depuis project root):
  \begin{verbatim}
  zip -r rendu_editeur.zip editor/ RAPPORT.md RAPPORT.pdf README.md
  \end{verbatim}
\end{itemize}
\end{frame}

